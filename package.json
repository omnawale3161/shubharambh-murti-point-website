{
  "name": "shubharambh-murti-point",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "seed:admin": "node scripts/seed-admin.mjs",
    "audit:production": "npm audit --omit=dev --audit-level=high",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build && npm run audit:production"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "next": "latest",
    "next-auth": "^5.0.0-beta.31",
    "react": "latest",
    "react-dom": "latest",
    "read-excel-file": "^9.2.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "25.9.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "latest",
    "tailwindcss": "^4.3.0",
    "typescript": "latest",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true
  }
}
